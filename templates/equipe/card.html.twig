{# templates/equipe/card.html.twig — Style PIDEV Java #}

{% set rang = (rankingByTeamId is defined and equipe.id in rankingByTeamId|keys)
    ? rankingByTeamId[equipe.id].rang
    : loop.index %}

<div class="roster-card">

    {# Rank badge top-left #}
    <span class="rc-rank">#{{ rang }}</span>

    {# Circular avatar with purple ring #}
    <div class="rc-avatar-wrap">
        <div class="rc-avatar-ring"></div>
        <div class="rc-avatar">
            {% if equipe.logo %}
                <img src="{{ asset('uploads/teams/' ~ equipe.logo) }}" alt="{{ equipe.nom }}">
            {% else %}
                <img src="{{ asset('img/logo.png') }}" alt="{{ equipe.nom }}">
            {% endif %}
        </div>
    </div>

    {# Team name #}
    <h2 class="rc-name">{{ equipe.nom }}</h2>

    {# Subtitle #}
    <p class="rc-sub">ESPORT TEAM</p>

    {# QR button — small, top-right of actions area #}
    <div class="rc-qr-row">
        <a href="{{ path('app_equipe_show', {id: equipe.id}) }}"
           class="rc-qr-btn" title="Voir l'équipe">
            <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/>
                <rect x="3" y="14" width="7" height="7"/><rect x="17" y="17" width="3" height="3"/>
                <rect x="14" y="14" width="3" height="3"/>
            </svg>
            QR
        </a>
    </div>

    {# Main action button #}
    {% if is_member|default(false) %}
        <a href="{{ path('app_equipe_dashboard', {id: equipe.id}) }}" class="rc-btn rc-btn-dash">
            Mon équipe →
        </a>
    {% elseif pendingTeamIds is defined and equipe.id in pendingTeamIds %}
        <span class="rc-btn rc-btn-pending">
            ⏳ Demande envoyée
        </span>
    {% else %}
        <a href="{{ path('app_equipe_join', {id: equipe.id}) }}" class="rc-btn rc-btn-join">
            Demander a joindre
        </a>
    {% endif %}

</div>
