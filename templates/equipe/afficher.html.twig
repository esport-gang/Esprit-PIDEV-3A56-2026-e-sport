{% extends 'base.html.twig' %}
{% block title %}Active Rosters · Esportify{% endblock %}

{% block body %}
<style>
/* ── Reset & Base ── */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

.rosters-page {
    min-height: 100vh;
    background: #0d1117;
    font-family: 'Segoe UI', system-ui, sans-serif;
    color: #e2e8f0;
    padding-bottom: 80px;
}

/* ── Header ── */
.rosters-header {
    background: #161b22;
    border-bottom: 1px solid #21262d;
    padding: 20px 40px;
    display: flex;
    align-items: center;
    gap: 16px;
}
.rosters-header .brand-title {
    font-size: 1.1rem;
    font-weight: 800;
    letter-spacing: 1px;
    color: #fff;
}
.rosters-header .brand-sub {
    font-size: 0.7rem;
    color: #6b7280;
    letter-spacing: 2px;
    text-transform: uppercase;
}
.rosters-header .header-right {
    margin-left: auto;
    display: flex;
    align-items: center;
    gap: 12px;
}
.cart-icon {
    width: 38px; height: 38px;
    border-radius: 8px;
    background: #21262d;
    border: 1px solid #30363d;
    display: flex; align-items: center; justify-content: center;
    color: #94a3b8; font-size: 1rem;
    text-decoration: none;
    transition: all 0.2s;
}
.cart-icon:hover { border-color: #7c3aed; color: #7c3aed; }

/* ── Hero ── */
.rosters-hero {
    padding: 48px 40px 32px;
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 20px;
    max-width: 1400px;
    margin: 0 auto;
}
.hero-text h1 {
    font-size: clamp(2.4rem, 5vw, 3.5rem);
    font-weight: 900;
    letter-spacing: -1px;
    color: #fff;
    margin-bottom: 6px;
}
.hero-text p {
    color: #6b7280;
    font-size: 1rem;
}
.hero-controls {
    display: flex;
    align-items: center;
    gap: 14px;
    flex-wrap: wrap;
}
.teams-counter {
    background: #21262d;
    border: 1px solid #30363d;
    border-radius: 14px;
    padding: 14px 22px;
    text-align: center;
    min-width: 90px;
}
.teams-counter .num {
    display: block;
    font-size: 1.8rem;
    font-weight: 900;
    color: #fff;
    line-height: 1;
}
.teams-counter .lbl {
    font-size: 0.65rem;
    color: #6b7280;
    letter-spacing: 2px;
    text-transform: uppercase;
    margin-top: 4px;
}
.btn-add-team {
    background: #7c3aed;
    color: #fff;
    border: none;
    padding: 14px 28px;
    border-radius: 14px;
    font-weight: 700;
    font-size: 1rem;
    cursor: pointer;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    transition: all 0.25s ease;
    box-shadow: 0 4px 20px rgba(124,58,237,0.4);
}
.btn-add-team:hover {
    background: #6d28d9;
    transform: translateY(-2px);
    box-shadow: 0 8px 28px rgba(124,58,237,0.55);
    color: #fff;
}

/* ── Search & Sort ── */
.rosters-toolbar {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 40px 28px;
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
}
.search-wrap {
    flex: 1; min-width: 200px; max-width: 400px;
    display: flex; align-items: center; gap: 10px;
    background: #161b22;
    border: 1px solid #30363d;
    border-radius: 12px;
    padding: 12px 16px;
    transition: border-color 0.2s;
}
.search-wrap:focus-within { border-color: #7c3aed; }
.search-wrap svg { color: #4b5563; flex-shrink: 0; }
.search-wrap input {
    background: none; border: none; outline: none;
    color: #e2e8f0; font-size: 0.95rem; width: 100%;
}
.search-wrap input::placeholder { color: #4b5563; }

.sort-select {
    background: #161b22;
    border: 1px solid #30363d;
    border-radius: 12px;
    padding: 12px 16px;
    color: #94a3b8;
    font-size: 0.9rem;
    outline: none;
    cursor: pointer;
    min-width: 140px;
}
.sort-select:focus { border-color: #7c3aed; }

/* ── Grid ── */
.rosters-grid {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 40px;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: 24px;
}

/* ── Roster Card (PIDEV Java style) ── */
.roster-card {
    background: #161b22;
    border: 1px solid #21262d;
    border-radius: 20px;
    padding: 28px 24px 24px;
    display: flex;
    flex-direction: column;
    align-items: center;
    position: relative;
    transition: all 0.3s cubic-bezier(.4,0,.2,1);
    overflow: hidden;
    animation: fadeCard 0.4s ease both;
}
.roster-card:hover {
    border-color: #7c3aed;
    transform: translateY(-6px);
    box-shadow: 0 20px 50px rgba(0,0,0,0.5), 0 0 30px rgba(124,58,237,0.12);
}

/* Rank badge */
.rc-rank {
    position: absolute;
    top: 16px; left: 18px;
    font-size: 0.85rem;
    font-weight: 700;
    color: #4b5563;
}

/* Avatar with purple ring */
.rc-avatar-wrap {
    position: relative;
    width: 100px; height: 100px;
    margin-bottom: 16px;
    margin-top: 8px;
}
.rc-avatar-ring {
    position: absolute;
    inset: -4px;
    border-radius: 50%;
    background: linear-gradient(135deg, #7c3aed, #a855f7, #6d28d9);
    z-index: 0;
}
.rc-avatar {
    position: absolute;
    inset: 3px;
    border-radius: 50%;
    overflow: hidden;
    background: #0d1117;
    z-index: 1;
}
.rc-avatar img {
    width: 100%; height: 100%;
    object-fit: cover;
    border-radius: 50%;
}

/* Name & subtitle */
.rc-name {
    font-size: 1.25rem;
    font-weight: 800;
    color: #fff;
    text-align: center;
    margin-bottom: 4px;
    letter-spacing: -0.3px;
}
.rc-sub {
    font-size: 0.72rem;
    font-weight: 600;
    color: #4b5563;
    letter-spacing: 2px;
    text-transform: uppercase;
    margin-bottom: 16px;
}

/* QR row */
.rc-qr-row {
    width: 100%;
    display: flex;
    justify-content: flex-end;
    margin-bottom: 12px;
}
.rc-qr-btn {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    background: rgba(124,58,237,0.15);
    color: #a78bfa;
    border: 1px solid rgba(124,58,237,0.3);
    padding: 5px 12px;
    border-radius: 8px;
    font-size: 0.75rem;
    font-weight: 700;
    text-decoration: none;
    transition: all 0.2s;
}
.rc-qr-btn:hover {
    background: rgba(124,58,237,0.3);
    color: #c4b5fd;
}

/* Action buttons */
.rc-btn {
    width: 100%;
    padding: 13px;
    border-radius: 12px;
    font-weight: 700;
    font-size: 0.92rem;
    text-align: center;
    cursor: pointer;
    text-decoration: none;
    border: none;
    display: block;
    transition: all 0.25s ease;
}
.rc-btn-join {
    background: #7c3aed;
    color: #fff;
    box-shadow: 0 4px 16px rgba(124,58,237,0.4);
}
.rc-btn-join:hover {
    background: #6d28d9;
    color: #fff;
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(124,58,237,0.5);
}
.rc-btn-dash {
    background: rgba(34,197,94,0.1);
    color: #22c55e;
    border: 1px solid rgba(34,197,94,0.25);
}
.rc-btn-dash:hover {
    background: rgba(34,197,94,0.2);
    color: #4ade80;
}
.rc-btn-pending {
    background: rgba(245,158,11,0.1);
    color: #f59e0b;
    border: 1px solid rgba(245,158,11,0.25);
    cursor: default;
    display: block;
    width: 100%; padding: 13px;
    border-radius: 12px;
    font-weight: 700; font-size: 0.92rem;
    text-align: center;
}

/* ── Empty ── */
.rosters-empty {
    grid-column: 1/-1;
    text-align: center;
    padding: 80px 20px;
    border: 1px dashed #21262d;
    border-radius: 20px;
    color: #4b5563;
}
.rosters-empty span { font-size: 3.5rem; display: block; margin-bottom: 16px; opacity: 0.5; }
.rosters-empty p { font-size: 1.1rem; margin-bottom: 20px; }

/* ── Animations ── */
@keyframes fadeCard {
    from { opacity: 0; transform: translateY(20px); }
    to   { opacity: 1; transform: translateY(0); }
}
.rosters-grid .roster-card:nth-child(1)  { animation-delay: 0.03s; }
.rosters-grid .roster-card:nth-child(2)  { animation-delay: 0.07s; }
.rosters-grid .roster-card:nth-child(3)  { animation-delay: 0.11s; }
.rosters-grid .roster-card:nth-child(4)  { animation-delay: 0.15s; }
.rosters-grid .roster-card:nth-child(5)  { animation-delay: 0.19s; }
.rosters-grid .roster-card:nth-child(6)  { animation-delay: 0.23s; }
.rosters-grid .roster-card:nth-child(7)  { animation-delay: 0.27s; }
.rosters-grid .roster-card:nth-child(8)  { animation-delay: 0.31s; }

@media (max-width: 640px) {
    .rosters-hero, .rosters-toolbar, .rosters-grid { padding-left: 16px; padding-right: 16px; }
    .rosters-grid { grid-template-columns: 1fr; }
}
</style>

<div class="rosters-page">

    {# ── Hero ── #}
    <div class="rosters-hero">
        <div class="hero-text">
            <h1>Active Rosters</h1>
            <p>Gérez et rejoignez les équipes esport</p>
        </div>
        <div class="hero-controls">
            <div class="teams-counter">
                <span class="num">{{ equipes|length }}</span>
                <span class="lbl">Teams</span>
            </div>
            {% if app.user %}
            <a href="{{ path('app_equipe_new') }}" class="btn-add-team">
                + Ajouter equipe
            </a>
            {% endif %}
        </div>
    </div>

    {# ── Toolbar ── #}
    <div class="rosters-toolbar">
        <div class="search-wrap">
            <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
            </svg>
            <input type="text" id="rosterSearch" placeholder="Rechercher une equipe..." autocomplete="off">
        </div>
        <select class="sort-select" id="rosterSort">
            <option value="name">Nom A-Z</option>
            <option value="name-desc">Nom Z-A</option>
            <option value="rank">Meilleur rang</option>
        </select>
    </div>

    {# ── Grid ── #}
    <div class="rosters-grid" id="rostersGrid">

        {% for equipe in equipes %}
            {% set is_member = user_team_ids is defined and equipe.id in user_team_ids %}
            {% include 'equipe/card.html.twig' with {
                equipe: equipe,
                is_member: is_member|default(false),
                rankingByTeamId: rankingByTeamId|default({}),
                pendingTeamIds: pendingTeamIds|default([])
            } %}
        {% else %}
            <div class="rosters-empty">
                <span>🎮</span>
                <p>Aucune équipe pour le moment.</p>
                {% if app.user %}
                <a href="{{ path('app_equipe_new') }}" class="rc-btn rc-btn-join" style="display:inline-block;width:auto;padding:13px 28px;">
                    Créer une équipe
                </a>
                {% endif %}
            </div>
        {% endfor %}

    </div>

</div>

<script>
(function () {
    const input  = document.getElementById('rosterSearch');
    const sort   = document.getElementById('rosterSort');
    const grid   = document.getElementById('rostersGrid');

    function getCards() {
        return [...grid.querySelectorAll('.roster-card')];
    }

    // Live search
    input.addEventListener('input', function () {
        const q = this.value.toLowerCase().trim();
        getCards().forEach(card => {
            const name = (card.querySelector('.rc-name')?.textContent || '').toLowerCase();
            card.style.display = (!q || name.includes(q)) ? '' : 'none';
        });
    });

    // Sort
    sort.addEventListener('change', function () {
        const cards = getCards();
        const sorted = cards.sort((a, b) => {
            const na = a.querySelector('.rc-name')?.textContent.trim() || '';
            const nb = b.querySelector('.rc-name')?.textContent.trim() || '';
            const ra = parseInt(a.querySelector('.rc-rank')?.textContent.replace('#','') || '999');
            const rb = parseInt(b.querySelector('.rc-rank')?.textContent.replace('#','') || '999');
            if (this.value === 'name')      return na.localeCompare(nb);
            if (this.value === 'name-desc') return nb.localeCompare(na);
            if (this.value === 'rank')      return ra - rb;
            return 0;
        });
        sorted.forEach(c => grid.appendChild(c));
    });
})();
</script>

{% endblock %}
