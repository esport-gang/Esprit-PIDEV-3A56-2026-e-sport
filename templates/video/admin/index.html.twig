{% extends 'admin/dashboard.html.twig' %}

{% block title %}Video Management{% endblock %}

{% block admin_content %}

<style>
.video-header {
    display:flex;
    justify-content:space-between;
    align-items:center;
    margin-bottom:20px;
}

.video-title {
    font-size:24px;
    font-weight:700;
    color:#fff;
}

.video-card {
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(148,163,184,0.1);
    border-radius: 16px;
    overflow:hidden;
    transition:0.3s;
}

.video-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 25px rgba(0,0,0,0.4);
}

.video-thumb {
    width:100%;
    height:180px;
    object-fit:cover;
}

.video-body {
    padding:15px;
}

.video-name {
    font-weight:600;
    color:#e2e8f0;
    margin-bottom:10px;
}

.custom-input {
    background:#0f172a;
    border:1px solid rgba(148,163,184,0.2);
    color:white;
    border-radius:10px;
}

.custom-input:focus {
    background:#0f172a;
    color:white;
    border-color:#6366f1;
    box-shadow:none;
}

.btn-upload {
    background: linear-gradient(135deg, #10b981, #059669);
    color:white;
    border:none;
    padding:10px 18px;
    border-radius:10px;
    font-weight:600;
}

.btn-delete {
    background:#ef4444;
    color:white;
    border:none;
    padding:6px 12px;
    border-radius:8px;
    font-size:13px;
}

.btn-watch {
    background:#2563eb;
    color:white;
    border:none;
    padding:6px 12px;
    border-radius:8px;
    font-size:13px;
}

.grid {
    display:grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap:20px;
    margin-top:20px;
}
</style>

<div class="video-header">
    <div class="video-title">🎬 Video Admin Panel</div>
    <div class="text-muted">{{ videos|length }} videos</div>
</div>

<!-- UPLOAD FORM -->
<div class="card mb-4 p-3" style="background:rgba(15,23,42,0.7); border:1px solid rgba(148,163,184,0.1);">

    <form action="{{ path('admin_video_upload') }}"
          method="POST"
          enctype="multipart/form-data"
          class="d-flex gap-2 flex-wrap">

        <input type="file"
               name="video"
               required
               class="form-control custom-input w-auto">

        <input type="text"
               name="title"
               placeholder="Video title..."
               required
               class="form-control custom-input w-auto flex-grow-1">

        <button class="btn-upload">
            ⬆ Upload
        </button>

    </form>
</div>

<!-- FLASH -->
{% for message in app.flashes('success') %}
    <div class="alert alert-success">{{ message }}</div>
{% endfor %}

{% for message in app.flashes('error') %}
    <div class="alert alert-danger">{{ message }}</div>
{% endfor %}

<!-- VIDEOS GRID -->
<div class="grid">

    {% for v in videos %}

        <div class="video-card">

            <img src="{{ v.thumbnail }}" class="video-thumb">

            <div class="video-body">

                <div class="video-name">
                    {{ v.title }}
                </div>

                <div class="d-flex justify-content-between">

                    <a href="{{ v.path }}" target="_blank" class="btn-watch">
                        ▶ Watch
                    </a>

                    <a href="{{ path('admin_video_delete', {id: v.id}) }}"
                       class="btn-delete"
                       onclick="return confirm('Delete this video ?')">
                        🗑 Delete
                    </a>

                </div>

            </div>

        </div>

    {% else %}

        <div class="text-center text-muted w-100 p-5">
            No videos uploaded yet 🎬
        </div>

    {% endfor %}

</div>

{% endblock %}