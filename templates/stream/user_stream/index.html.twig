{% extends 'base.html.twig' %}

{% block title %}Live Stream{% endblock %}

{% block body %}

<div style="min-height:100vh;background:#0f172a;padding:40px;">

<div class="container-fluid">

<div class="row">

<!-- ================= VIDEO ================= -->
<div class="col-lg-8">

<div style="background:#111827;border-radius:20px;overflow:hidden;">

<div style="padding:20px;color:white;display:flex;justify-content:space-between;">
    <h3>🔴 LIVE STREAM</h3>
    <span style="color:red;">LIVE</span>
</div>

{% if stream %}

<video id="videoPlayer"
       controls
       autoplay
       style="width:100%;height:650px;background:black;"></video>

{% else %}

<div style="height:500px;display:flex;align-items:center;justify-content:center;color:white;">
    No Stream
</div>

{% endif %}

</div>

</div>

<!-- ================= CHAT ================= -->
<div class="col-lg-4">

<div style="background:#111827;height:100%;display:flex;flex-direction:column;border-radius:20px;">

<div style="padding:15px;color:white;">
    💬 Live Chat
</div>

<!-- CHAT BOX -->
<div id="chatBox"
     style="flex:1;overflow:auto;padding:15px;color:white;background:#0f172a;">
</div>

<!-- INPUT -->
<div style="padding:10px;">

<div class="d-flex">
    <input id="messageInput" class="form-control" placeholder="message...">
    <button class="btn btn-danger ms-2" onclick="sendMessage()">Send</button>
</div>

<!-- REACTIONS -->
<div class="d-flex justify-content-center gap-2 mt-2">

    <button class="btn btn-dark" onclick="sendReaction('like')">👍</button>
    <button class="btn btn-dark" onclick="sendReaction('love')">❤️</button>
    <button class="btn btn-dark" onclick="sendReaction('haha')">😂</button>
    <button class="btn btn-dark" onclick="sendReaction('wow')">😮</button>

</div>

</div>

</div>

</div>

</div>

</div>

</div>

{% if stream %}

<script src="https://cdn.jsdelivr.net/npm/hls.js"></script>

<script>
document.addEventListener("DOMContentLoaded", function () {

    /* ================= STREAM ================= */
    const video = document.getElementById('videoPlayer');
    const streamUrl = "{{ stream.url }}";

    if (video && streamUrl) {
        if (Hls.isSupported()) {
            const hls = new Hls();
            hls.loadSource(streamUrl);
            hls.attachMedia(video);
        } else {
            video.src = streamUrl;
        }
    }

    /* ================= STREAM ID ================= */
    const streamId = {{ stream.id|default(1) }};

    /* ================= MERCURE ================= */
    const eventSource = new EventSource(
        "http://127.0.0.1:3000/.well-known/mercure?topic=stream/" + streamId
    );

    eventSource.onmessage = (event) => {

        const data = JSON.parse(event.data);
        const box = document.getElementById("chatBox");

        if (!box) return;

        /* CHAT */
        if (data.type === "chat") {
            box.innerHTML += `
                <div style="background:#2563eb;padding:8px;border-radius:10px;margin-bottom:8px;">
                    <b>${data.user}</b>: ${data.message}
                </div>
            `;
        }

        /* REACTION */
        if (data.type === "reaction") {
            box.innerHTML += `
                <div style="color:#facc15;margin-bottom:5px;">
                    ${data.emoji} reaction
                </div>
            `;
        }

        box.scrollTop = box.scrollHeight;
    };

    /* ================= SEND MESSAGE ================= */
    window.sendMessage = function () {

        const input = document.getElementById("messageInput");
        const text = input.value;

        if (!text.trim()) return;

        fetch(`/stream/chat/${streamId}`, {
            method: "POST",
            headers: {'Content-Type': 'application/json'},
            body: JSON.stringify({
                message: text,
                user: "User"
            })
        });

        input.value = "";
    };

    /* ================= SEND REACTION ================= */
    window.sendReaction = function (type) {

        fetch(`/stream/react/${streamId}/${type}`, {
            method: "POST"
        });
    };

});
</script>

{% endif %}

{% endblock %}